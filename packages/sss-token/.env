# Network to connect to
# Use "localnet", "devnet", "testnet", "mainnet" or a custom URL like "https://api.devnet.solana.com"
RPC_URL=localnet

# Solana Keypair paths
# Make sure to create these or point them to your actual ~/.config/solana/id.json

# If you use a custom transfer hook program, specify it here.
# Otherwise, it defaults to the 'transfer_hook' program ID deployed along with 'stc_program'.
TRANSFER_HOOK_PROGRAM_ID=FtPdSNiQ8ieM4yE1V8FekUk7WDbgZrx9ehb3CyaXzHtG