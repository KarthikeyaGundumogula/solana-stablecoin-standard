# Solana Keypair paths
# Make sure to create these or point them to your actual ~/.config/solana/id.json
ADMIN_KEYPAIR=./admin.json
MINT_KEYPAIR=./mint.json

# Network to connect to
# Use "localnet", "devnet", "testnet", "mainnet" or a custom URL like "https://api.devnet.solana.com"
RPC_URL=localnet
