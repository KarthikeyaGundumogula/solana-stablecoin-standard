{
  "name": "@stbr/sss-token",
  "version": "0.1.0",
  "description": "SDK for Solana Stablecoin Standard (SSS) Anchor programs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sss-token": "dist-cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist-cli/cli.js --packages=external",
    "generate": "ts-node generate-clients.ts && yarn prettier",
    "prettier": "prettier --write \"src/generated/**/*.ts\""
  },
  "dependencies": {
    "@codama/cli": "^1.5.0",
    "@codama/nodes-from-anchor": "^1.3.9",
    "@codama/renderers": "^1.0.34",
    "@codama/renderers-js": "^1.7.0",
    "@solana/program-client-core": "^6.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^25.3.5",
    "codama": "^1.5.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gill": "^0.14.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
